# scorm-mcp ortam değişkenleri — bkz. CONTRACTS.md §8
PUBLIC_BASE_URL=https://mcp.edumints.com/scorm
ROOT_PATH=/scorm
DATA_DIR=/data
PORT=8000

# Maliyet guardrail'leri
PACKAGE_TTL_DAYS=7
MAX_PROJECT_MB=50
MAX_PROJECTS_PER_KEY=100
MAX_ASSET_MB=25

# Build / runtime
BUILD_WORKERS=8
BUILD_SYNC_TIMEOUT_SEC=4
SCORM_DEFAULT_VERSION=1.2
DB_PATH=/data/scorm.db
PREVIEW_TTL_MIN=60
LOG_LEVEL=INFO
