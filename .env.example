# scorm-mcp environment — copy to .env and adjust. Defaults below suit local self-hosting.
PUBLIC_BASE_URL=http://localhost:8000
ROOT_PATH=
DATA_DIR=/data
PORT=8000

# Maliyet guardrail'leri
PACKAGE_TTL_DAYS=7
MAX_PROJECT_MB=50
MAX_PROJECTS_PER_KEY=100
MAX_ASSET_MB=25

# Build / runtime
BUILD_WORKERS=8
BUILD_SYNC_TIMEOUT_SEC=4
SCORM_DEFAULT_VERSION=1.2
DB_PATH=/data/scorm.db
PREVIEW_TTL_MIN=60
LOG_LEVEL=INFO
