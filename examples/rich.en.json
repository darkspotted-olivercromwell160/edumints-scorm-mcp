{
  "title": "Interactive Showcase (Rich)",
  "description": "Showcasing all 18 available screen types",
  "scorm_version": "1.2",
  "language": "en",
  "theme": "agency",
  "tracking": {
    "completion_rule": "viewed_all_and_passed",
    "passing_score": 60
  },
  "assets": [
    {
      "id": "logo",
      "filename": "logo.png",
      "source": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNgYGBgAAAABQABAKChqAAAAABJRUVORK5CYII="
    },
    {
      "id": "scene",
      "filename": "scene.png",
