      "options": [
        { "id": "a", "text_html": "Apple", "correct": true },
        { "id": "b", "text_html": "Carrot" },
        { "id": "c", "text_html": "Banana", "correct": true }
      ],
      "points": 10
    },
    {
      "type": "true_false",
      "id": "s-tf",
      "title": "True or False",
      "prompt_html": "<p>The chemical symbol for water is H2O.</p>",
      "correct": true,
      "points": 5
    },
    {
      "type": "fill_blank",
      "id": "s-fill",
      "title": "Fill in the Blank",
      "prompt_html": "<p>SCORM stands for Sharable Content Object ___ Model.</p>",
      "blanks": [
        { "id": "b1", "accepted": ["Reference", "reference"] }
      ],
      "points": 5
    },
    {
      "type": "drag_drop",
      "id": "s-drag",
      "title": "Drag and Drop",
      "prompt_html": "<p>Match the countries to their capitals.</p>",
      "items": [
        { "id": "i1", "text_html": "France", "correct_target_id": "d1" },
        { "id": "i2", "text_html": "Italy", "correct_target_id": "d2" }
      ],
      "targets": [
        { "id": "d1", "label_html": "Paris" },
        { "id": "d2", "label_html": "Rome" }
      ],
      "points": 10
    },
    {
      "type": "hotspot",
      "id": "s-hotspot",
      "title": "Hotspot",
      "prompt_html": "<p>Click on the target area in the image.</p>",
      "image_asset_id": "scene",
      "regions": [
        { "id": "r1", "shape": "rect", "coords": [0, 0, 1, 1], "correct": true, "label_html": "Target Area" }
      ],
      "points": 10
    },
    {
      "type": "branching",
      "id": "s-branch",
      "title": "Branching Scenario",
