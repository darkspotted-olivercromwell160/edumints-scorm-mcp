  ],
  "screens": [
    {
      "type": "title_slide",
      "id": "s-title",
      "title": "Interactive Showcase",
      "subtitle": "Explore all 18 screen types",
      "body_html": "<p>Welcome to this comprehensive demo of the SCORM MCP capabilities.</p>"
    },
    {
      "type": "content_slide",
      "id": "s-content",
      "title": "Content Slide",
      "layout": "text_media",
      "media_asset_id": "logo",
      "body_html": "<p>This is a standard content slide with text and media.</p>"
    },
    {
      "type": "mcq",
      "id": "s-mcq",
      "title": "Multiple Choice",
      "prompt_html": "<p>Which of these are fruits? (Select all that apply)</p>",
