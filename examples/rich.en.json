        { "id": "p2", "left_html": "Cat", "right_html": "Meow" }
      ],
      "points": 10
    },
    {
      "type": "sorting",
      "id": "s-sorting",
      "title": "Sorting Task",
      "prompt_html": "<p>Sort these by size (Smallest to Largest).</p>",
