{
  "name": "agency",
  "typography": {
    "font_heading": "'Sora','Inter',system-ui,sans-serif",
    "font_body": "'Inter',system-ui,sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 16,
    "scale_ratio": 1.333,
    "weight_heading": 800,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.2,
    "line_height_normal": 1.6,
    "letter_spacing_heading": "-0.02em"
  },
  "color": {
    "primary": "#4f46e5",
    "primary_hover": "#4338ca",
    "primary_contrast": "#ffffff",
    "secondary": "#db2777",
    "accent": "#f59e0b",
    "bg": "#ffffff",
    "surface": "#ffffff",
    "surface_alt": "#f5f3ff",
    "border": "#e9e5ff",
    "text": "#0b1020",
    "text_muted": "#5b6478",
    "text_on_dark": "#f8fafc",
    "success": "#16a34a",
    "success_bg": "#dcfce7",
    "error": "#dc2626",
    "error_bg": "#fee2e2",
    "warning": "#d97706",
    "info": "#0284c7",
    "focus_ring": "#4f46e5"
  },
  "spacing": {
    "base_px": 4,
    "scale": [
      0,
      4,
      8,
      12,
      16,
      24,
      32,
      48,
      64,
      96
    ],
    "content_max_width": "880px",
    "gutter": "clamp(16px, 4vw, 48px)"
  },
  "radii": {
    "none": "0",
    "sm": "6px",
    "md": "12px",
    "lg": "20px",
    "pill": "999px"
  },
  "elevation": {
    "e0": "none",
    "e1": "0 2px 4px rgba(79,70,229,.10), 0 1px 2px rgba(11,16,32,.06)",
    "e2": "0 8px 18px -6px rgba(79,70,229,.18), 0 4px 8px -4px rgba(11,16,32,.10)",
    "e3": "0 18px 40px -12px rgba(79,70,229,.28), 0 8px 16px -8px rgba(11,16,32,.12)",
    "e4": "0 30px 60px -15px rgba(79,70,229,.32), 0 12px 24px -10px rgba(11,16,32,.14)"
  },
  "motion": {
    "duration_fast": "120ms",
    "duration_base": "260ms",
    "duration_slow": "400ms",
    "easing_standard": "cubic-bezier(0.2, 0, 0, 1)",
    "easing_emphasized": "cubic-bezier(0.2,0,0,1.3)",
    "slide_transition": "slide",
    "reduce_motion_respect": true
  },
  "logo_asset_id": null,
  "background_pattern": "gradient",
