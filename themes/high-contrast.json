{
  "name": "high-contrast",
  "typography": {
    "font_heading": "'Atkinson Hyperlegible', 'Inter', system-ui, -apple-system, sans-serif",
    "font_body": "'Atkinson Hyperlegible', 'Inter', system-ui, -apple-system, sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 18,
