{
  "name": "modern-light",
  "typography": {
    "font_heading": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_body": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 16,
    "scale_ratio": 1.27,
    "weight_heading": 800,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.15,
    "line_height_normal": 1.6,
    "letter_spacing_heading": "-0.02em"
  },
  "color": {
    "primary": "#0d9488",
    "primary_hover": "#0f766e",
    "primary_contrast": "#ffffff",
    "secondary": "#6366f1",
    "accent": "#f59e0b",
    "bg": "#ffffff",
    "surface": "#f6fdfb",
    "surface_alt": "#ecfbf7",
    "border": "#d6ece7",
    "text": "#0b1f1c",
    "text_muted": "#5b716c",
    "text_on_dark": "#f0fdfa",
    "success": "#16a34a",
    "success_bg": "#dcfce7",
    "error": "#dc2626",
    "error_bg": "#fee2e2",
    "warning": "#d97706",
    "info": "#0891b2",
    "focus_ring": "#0d9488"
  },
  "background_pattern": "dots"
}
