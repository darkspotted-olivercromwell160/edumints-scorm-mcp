{
  "name": "boardroom-clinic",
  "typography": {
    "font_heading": "'Source Sans 3', 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_body": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 16,
    "scale_ratio": 1.25,
    "weight_heading": 600,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.2,
    "line_height_normal": 1.6,
    "letter_spacing_heading": "-0.01em"
  },
  "color": {
    "primary": "#0f172a",
    "primary_hover": "#1e293b",
    "primary_contrast": "#ffffff",
    "secondary": "#0f766e",
    "accent": "#0f766e",
    "bg": "#f8fafc",
    "surface": "#ffffff",
    "surface_alt": "#f1f5f9",
    "border": "#e2e8f0",
    "text": "#1e293b",
    "text_muted": "#475569",
    "text_on_dark": "#f8fafc",
    "success": "#15803d",
    "success_bg": "#f0fdf4",
    "error": "#b91c1c",
    "error_bg": "#fef2f2",
    "warning": "#a66e0e",
    "info": "#0369a1",
    "focus_ring": "#0ea5e9"
  },
  "spacing": {
    "base_px": 4,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96],
    "content_max_width": "880px",
    "gutter": "clamp(16px, 4vw, 48px)"
  },
  "radii": {
    "none": "0",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "pill": "999px"
  },
  "elevation": {
    "e0": "none",
    "e1": "0 1px 2px rgba(15,23,42,.06), 0 1px 3px rgba(15,23,42,.10)",
    "e2": "0 4px 6px -1px rgba(15,23,42,.10), 0 2px 4px -2px rgba(15,23,42,.10)",
    "e3": "0 10px 15px -3px rgba(15,23,42,.10), 0 4px 6px -4px rgba(15,23,42,.10)",
    "e4": "0 20px 25px -5px rgba(15,23,42,.12), 0 8px 10px -6px rgba(15,23,42,.10)"
  },
  "motion": {
    "duration_fast": "120ms",
    "duration_base": "220ms",
    "duration_slow": "400ms",
    "easing_standard": "cubic-bezier(0.2, 0, 0, 1)",
    "easing_emphasized": "cubic-bezier(0.2, 0, 0, 1.2)",
    "slide_transition": "slide",
    "reduce_motion_respect": true
  },
  "logo_asset_id": null,
  "background_pattern": "none",
  "custom_css": ".screen-inner{border-top:4px solid var(--c-primary);box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);padding-top:2rem} .screen-title{display:inline-block;border-bottom:2px solid var(--c-secondary);padding-bottom:0.25rem;margin-bottom:1.5rem;font-weight:700} .btn-primary{border-radius:4px;font-weight:600;text-transform:none;letter-spacing:0.01em} .opt,.branch-choice,.scen-choice{border-radius:6px;border:1px solid var(--c-border);transition:all 0.2s ease-in-out} .opt:hover{border-color:var(--c-secondary);background:var(--c-surface-alt)} .logo-placeholder{width:180px;height:45px;background:var(--c-surface-alt);border:1px dashed var(--c-border);display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--c-text-muted);margin-bottom:1rem}"
}
