{
  "name": "dark",
  "typography": {
    "font_heading": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_body": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 16,
    "scale_ratio": 1.25,
    "weight_heading": 700,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.2,
    "line_height_normal": 1.6,
    "letter_spacing_heading": "-0.01em"
  },
  "color": {
    "primary": "#60a5fa",
    "primary_hover": "#3b82f6",
    "primary_contrast": "#0b1020",
    "secondary": "#a78bfa",
    "accent": "#22d3ee",
    "bg": "#0b1020",
    "surface": "#121a2e",
    "surface_alt": "#1b2540",
    "border": "#26324f",
    "text": "#e6ebf5",
    "text_muted": "#94a3b8",
    "text_on_dark": "#e6ebf5",
    "success": "#34d399",
    "success_bg": "#0c2a22",
    "error": "#f87171",
    "error_bg": "#2a1414",
    "warning": "#fbbf24",
    "info": "#38bdf8",
    "focus_ring": "#60a5fa"
  },
  "spacing": {
    "base_px": 4,
    "scale": [
      0,
      4,
      8,
      12,
      16,
      24,
      32,
      48,
      64,
      96
    ],
    "content_max_width": "880px",
    "gutter": "clamp(16px, 4vw, 48px)"
  },
  "radii": {
    "none": "0",
    "sm": "6px",
    "md": "12px",
    "lg": "20px",
    "pill": "999px"
  },
  "elevation": {
    "e0": "none",
    "e1": "0 1px 2px rgba(0,0,0,.4)",
    "e2": "0 6px 14px -4px rgba(0,0,0,.5)",
    "e3": "0 14px 28px -8px rgba(0,0,0,.55)",
    "e4": "0 24px 44px -12px rgba(0,0,0,.6)"
  },
  "motion": {
    "duration_fast": "120ms",
    "duration_base": "220ms",
    "duration_slow": "400ms",
    "easing_standard": "cubic-bezier(0.2, 0, 0, 1)",
    "easing_emphasized": "cubic-bezier(0.2, 0, 0, 1.2)",
    "slide_transition": "slide",
    "reduce_motion_respect": true
  },
  "logo_asset_id": null,
  "background_pattern": "dots",
  "custom_css": null
