  },
  "color": {
    "primary": "#c2410c",
    "primary_hover": "#9a3412",
    "primary_contrast": "#ffffff",
    "secondary": "#b45309",
    "accent": "#ea580c",
    "bg": "#fffaf0",
    "surface": "#ffffff",
    "surface_alt": "#ffedd5",
    "border": "#fed7aa",
    "text": "#431407",
    "text_muted": "#7c2d12",
    "text_on_dark": "#fffaf0",
    "success": "#15803d",
    "success_bg": "#f0fdf4",
    "error": "#b91c1c",
    "error_bg": "#fef2f2",
