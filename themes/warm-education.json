{
  "name": "warm-education",
  "typography": {
    "font_heading": "'Sora', system-ui, sans-serif",
    "font_body": "'Inter', system-ui, sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 17,
    "scale_ratio": 1.25,
    "weight_heading": 700,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.2,
    "line_height_normal": 1.65,
