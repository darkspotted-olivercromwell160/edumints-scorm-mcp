    "e3": "0 10px 15px -3px rgba(67,20,7,.10), 0 4px 6px -4px rgba(67,20,7,.10)",
    "e4": "0 20px 25px -5px rgba(67,20,7,.12), 0 8px 10px -6px rgba(67,20,7,.10)"
