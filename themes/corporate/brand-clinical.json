{
  "name": "brand-clinical",
  "typography": {
    "font_heading": "'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "font_body": "'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "font_mono": "monospace",
    "base_size_px": 16,
    "scale_ratio": 1.2,
    "weight_heading": 600,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.3,
    "line_height_normal": 1.5,
    "letter_spacing_heading": "0"
  },
  "color": {
    "primary": "#0f766e",
    "primary_hover": "#0d5c56",
    "primary_contrast": "#ffffff",
    "secondary": "#64748b",
    "accent": "#f43f5e",
    "bg": "#ffffff",
    "surface": "#f8fafc",
    "surface_alt": "#f1f5f9",
    "border": "#e2e8f0",
    "text": "#0f172a",
    "text_muted": "#64748b",
    "text_on_dark": "#ffffff",
    "success": "#10b981",
    "success_bg": "#ecfdf5",
    "error": "#ef4444",
    "error_bg": "#fef2f2",
    "warning": "#f59e0b",
    "info": "#3b82f6",
    "focus_ring": "#0d9488"
  },
  "spacing": {
    "base_px": 4,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96],
    "content_max_width": "1024px",
    "gutter": "32px"
  },
  "radii": {
    "none": "0",
    "sm": "2px",
    "md": "4px",
    "lg": "8px",
    "pill": "999px"
  },
  "elevation": {
    "e0": "none",
    "e1": "0 1px 3px rgba(0,0,0,0.12)",
    "e2": "0 4px 6px rgba(0,0,0,0.08)",
    "e3": "0 10px 15px rgba(0,0,0,0.05)",
    "e4": "0 20px 25px rgba(0,0,0,0.05)"
  },
  "motion": {
    "duration_fast": "150ms",
    "duration_base": "250ms",
    "duration_slow": "400ms",
    "easing_standard": "linear",
    "easing_emphasized": "ease-in",
    "slide_transition": "slide",
    "reduce_motion_respect": true
  },
  "logo_asset_id": null,
  "background_pattern": "dots",
  "custom_css": null
}
