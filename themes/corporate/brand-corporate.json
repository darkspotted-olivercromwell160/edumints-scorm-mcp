{
  "name": "brand-corporate",
  "typography": {
    "font_heading": "'Inter', system-ui, -apple-system, sans-serif",
    "font_body": "'Inter', system-ui, -apple-system, sans-serif",
    "font_mono": "ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 16,
    "scale_ratio": 1.25,
    "weight_heading": 700,
    "weight_body": 400,
    "weight_strong": 600,
    "line_height_tight": 1.2,
    "line_height_normal": 1.6,
    "letter_spacing_heading": "-0.01em"
  },
  "color": {
    "primary": "#004dcf",
    "primary_hover": "#003794",
    "primary_contrast": "#ffffff",
    "secondary": "#6b7280",
    "accent": "#0ea5e9",
    "bg": "#ffffff",
    "surface": "#f9fafb",
    "surface_alt": "#f3f4f6",
    "border": "#e5e7eb",
    "text": "#111827",
    "text_muted": "#6b7280",
    "text_on_dark": "#ffffff",
    "success": "#059669",
    "success_bg": "#ecfdf5",
    "error": "#dc2626",
    "error_bg": "#fef2f2",
    "warning": "#d97706",
    "info": "#2563eb",
    "focus_ring": "#004dcf"
  },
  "spacing": {
    "base_px": 4,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96],
    "content_max_width": "960px",
    "gutter": "24px"
  },
  "radii": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "999px"
  },
  "elevation": {
    "e0": "none",
    "e1": "0 1px 2px rgba(0,0,0,0.05)",
    "e2": "0 4px 6px -1px rgba(0,0,0,0.1)",
    "e3": "0 10px 15px -3px rgba(0,0,0,0.1)",
    "e4": "0 20px 25px -5px rgba(0,0,0,0.1)"
  },
  "motion": {
    "duration_fast": "100ms",
    "duration_base": "200ms",
    "duration_slow": "300ms",
    "easing_standard": "ease-in-out",
    "easing_emphasized": "cubic-bezier(0.4, 0, 0.2, 1)",
    "slide_transition": "fade",
    "reduce_motion_respect": true
  },
  "logo_asset_id": null,
  "background_pattern": "none",
  "custom_css": null
}
