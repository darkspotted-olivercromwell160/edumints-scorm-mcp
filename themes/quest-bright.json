{
  "name": "quest-bright",
  "typography": {
    "font_heading": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_body": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "base_size_px": 16,
    "scale_ratio": 1.3,
    "weight_heading": 900,
    "weight_body": 400,
    "weight_strong": 700,
    "line_height_tight": 1.1,
    "line_height_normal": 1.6,
    "letter_spacing_heading": "-0.03em"
  },
  "color": {
    "primary": "#7c3aed",
    "primary_hover": "#6d28d9",
    "primary_contrast": "#ffffff",
    "secondary": "#db2777",
    "accent": "#0369a1",
    "bg": "#ffffff",
    "surface": "#f8faff",
    "surface_alt": "#f0f4ff",
    "border": "#e0e7ff",
    "text": "#0f172a",
    "text_muted": "#475569",
    "text_on_dark": "#ffffff",
    "success": "#047857",
    "success_bg": "#ecfdf5",
    "error": "#e11d48",
    "error_bg": "#fff1f2",
    "warning": "#b45309",
    "info": "#2563eb",
    "focus_ring": "#a78bfa"
  },
  "spacing": {
    "base_px": 4,
    "scale": [
      0,
      4,
      8,
      12,
      16,
      24,
      32,
      48,
      64,
      96
    ],
    "content_max_width": "900px",
    "gutter": "clamp(16px, 5vw, 40px)"
  },
  "radii": {
    "none": "0",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "pill": "999px"
  },
  "elevation": {
    "e0": "none",
    "e1": "0 2px 4px rgba(124, 58, 237, 0.08)",
    "e2": "0 4px 8px rgba(124, 58, 237, 0.1)",
    "e3": "0 8px 16px rgba(124, 58, 237, 0.12)",
    "e4": "0 16px 32px rgba(124, 58, 237, 0.14)"
  },
  "motion": {
    "duration_fast": "150ms",
    "duration_base": "300ms",
    "duration_slow": "500ms",
    "easing_standard": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easing_emphasized": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "slide_transition": "slide",
    "reduce_motion_respect": true
  },
  "background_pattern": "dots"
}
